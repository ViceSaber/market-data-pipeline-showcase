# Public Showcase Configuration Template
# Copy to config.yaml for local experimentation.

project:
  name: market-data-pipeline-showcase
  timezone: Asia/Shanghai

database:
  path: ./polymarket_scanner/data/polymarket.db
  journal_mode: WAL
  busy_timeout_ms: 30000

api:
  gamma_base_url: https://gamma-api.polymarket.com
  max_requests_per_window: 200
  window_seconds: 10

refresh:
  hot_interval_seconds: 300
  warm_interval_seconds: 900
  cold_interval_seconds: 3600
  retention_hours: 72

runtime:
  batch_size: 20
  stale_hours: 24

notifications:
  enabled: false
  channel: telegram
